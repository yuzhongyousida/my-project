<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.product.mapper.UserMapper">
    <select id="selectUserById" resultType="com.demo.product.entity.User">
        SELECT id, username, phone, age FROM user WHERE id = #{id}
    </select>

    <select id="selectAllUsers" resultType="com.demo.product.entity.User">
        SELECT id, username, phone, age FROM user
    </select>

    <insert id="insertUser" parameterType="com.demo.product.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, phone, age) VALUES (#{username}, #{phone}, #{age})
    </insert>
</mapper>